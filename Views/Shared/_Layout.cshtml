<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - FirstMVCApp</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/css/tailwind.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/FirstMVCApp.styles.css" asp-append-version="true" />
</head>
<body class="min-h-screen bg-slate-50 text-slate-900 antialiased">
    <header class="border-b border-slate-200 bg-white shadow-sm">
        <nav class="mx-auto flex max-w-6xl items-center justify-between px-4 py-4 sm:px-6 lg:px-8">
            <a class="text-lg font-semibold text-slate-950" asp-area="" asp-controller="Home" asp-action="Index">FirstMVCApp</a>
            <div class="flex items-center gap-4 text-sm font-medium">
                <a class="text-slate-700 transition hover:text-slate-950" asp-area="" asp-controller="Home" asp-action="Index">Home</a>
                <a class="text-slate-700 transition hover:text-slate-950" asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
            </div>
        </nav>
    </header>

    <div class="mx-auto min-h-[calc(100vh-9rem)] max-w-6xl px-4 py-8 sm:px-6 lg:px-8">
        <main role="main">
            @RenderBody()
        </main>
    </div>

    <footer class="border-t border-slate-200 bg-white">
        <div class="mx-auto max-w-6xl px-4 py-5 text-sm text-slate-600 sm:px-6 lg:px-8">
            &copy; 2026 - FirstMVCApp - <a class="font-medium text-slate-700 hover:text-slate-950" asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
